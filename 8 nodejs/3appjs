// 注意：使用require()方法加载其他模块时 ，会执行被加载模块中的代码。
// 1. 引入 test.js 模块（注意使用相对路径 ./ ）
const custom = require('./test.js')

// 2. 打印引入进来的对象
console.log('在 3 模块化.js 中接收到的数据：', custom);
console.log('访问名字：', custom.name);
